<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Launcher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="780"
        x:Class="Launcher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Lelbry M&amp;B II Balance Launcher"
        Width="1000" Height="780"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="16">

            <TextBlock Grid.Row="0" Text="Lelbry Balance Fixes" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>

            <Grid Grid.Row="1" ColumnDefinitions="2*,*" Height="280">

                <Border Grid.Column="0" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Text="Правки баланса" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ScrollViewer Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding Fixes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FixViewModel">
                                        <Border BorderBrush="#2a2a2a" BorderThickness="0,0,0,1" Padding="0,6">
                                            <StackPanel>
                                                <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Title}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Description}" Margin="22,2,0,0" Foreground="#bbbbbb" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="1" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="4" Padding="8">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Настройки" FontWeight="Bold"/>

                        <TextBlock Text="Путь к игре:" Margin="0,4,0,0"/>
                        <TextBox Text="{Binding GamePath}" Watermark="E:\...\Mount &amp; Blade II Bannerlord"/>

                        <TextBlock Text="Способ запуска:" Margin="0,4,0,0"/>
                        <RadioButton GroupName="launch" Content="Прямой (Bannerlord.exe)" IsChecked="{Binding IsDirectMethod}"/>
                        <RadioButton GroupName="launch" Content="Через Steam" IsChecked="{Binding IsSteamMethod}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Live Tuning panel -->
            <Border Grid.Row="2" BorderBrush="#3a3a3a" BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,12,0,0"
                    DataContext="{Binding LiveTuning}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Тонкая настройка (применяется без перезапуска игры)" FontWeight="Bold" FontSize="14"/>

                    <Grid ColumnDefinitions="Auto,Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Бонус к лимиту отряда:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                       Value="{Binding PartySizeBonus}"
                                       Minimum="-200" Maximum="1000" Increment="10" FormatString="0"
                                       Width="140"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="человек" VerticalAlignment="Center" Margin="8,0,0,0"/>

                        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Content="-100" Command="{Binding AdjustPartySizeCommand}" CommandParameter="-100" Foreground="#ff8888"/>
                            <Button Content="-50"  Command="{Binding AdjustPartySizeCommand}" CommandParameter="-50"  Foreground="#ff8888"/>
                            <Button Content="-20"  Command="{Binding AdjustPartySizeCommand}" CommandParameter="-20"  Foreground="#ff8888"/>
                            <Border Width="12"/>
                            <Button Content="+20"  Command="{Binding AdjustPartySizeCommand}" CommandParameter="20"  Foreground="#88ff88"/>
                            <Button Content="+50"  Command="{Binding AdjustPartySizeCommand}" CommandParameter="50"  Foreground="#88ff88"/>
                            <Button Content="+100" Command="{Binding AdjustPartySizeCommand}" CommandParameter="100" Foreground="#88ff88"/>
                            <Border Width="20"/>
                            <Button Content="Сбросить (=0)" Command="{Binding ResetPartySizeCommand}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="3"
                                   Text="{Binding LiveHintText}"
                                   Foreground="#9ec1ff" Margin="0,8,0,0"/>
                    </Grid>

                    <Border BorderBrush="#2a2a2a" BorderThickness="0,1,0,0" Margin="0,4,0,0"/>

                    <CheckBox Content="Полный лут с врагов включён" IsChecked="{Binding FullLootEnabled}"/>

                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Text="{Binding AppliedAt}" Foreground="#888" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="⚠ Не применено" Foreground="#ffb24d"
                                   VerticalAlignment="Center" Margin="0,0,12,0"
                                   IsVisible="{Binding IsDirty}"/>
                        <Button   Grid.Column="2" Content="Применить к игре"
                                 Command="{Binding ApplyCommand}"
                                 Padding="14,8" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Margin="0,12,0,0" Foreground="#ddd" TextWrapping="Wrap"/>

            <Button Grid.Row="4" Content="Запустить Bannerlord"
                    Command="{Binding LaunchCommand}"
                    HorizontalAlignment="Right"
                    Padding="20,10" Margin="0,12,0,0"
                    FontWeight="Bold"/>
        </Grid>
    </ScrollViewer>
</Window>
